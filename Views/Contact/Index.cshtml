@{
    ViewData["Title"] = "İletişim"; ViewData["Page"] = "Contact";
}

<div class="org-page-header">
    <div class="org-page-header-content">
        <h1>İletişim</h1>
        <div class="org-breadcrumb">
            <span class="org-breadcrumb-icon">🏠</span>
            <a asp-controller="Home" asp-action="Index">Ana Sayfa</a>
            <span>›</span>
            <span style="color:white">İletişim</span>
        </div>
    </div>
</div>

<div class="container" style="padding-top:48px;padding-bottom:64px">

    @if (TempData["Success"] != null)
    {
        <div class="org-alert org-alert--success" style="max-width:700px;margin:0 auto 24px">
            ✓ @TempData["Success"]
        </div>
    }

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;max-width:1000px;margin:0 auto">

        <!-- Sol: İletişim Bilgileri -->
        <div>
            <h2 style="font-size:22px;font-weight:800;color:#1a1a1a;margin-bottom:8px">Bizimle İletişime Geçin</h2>
            <p style="color:#666;font-size:14px;line-height:1.7;margin-bottom:32px">Sorularınız, önerileriniz veya şikayetleriniz için bize ulaşabilirsiniz. En kısa sürede dönüş yapacağız.</p>

            <div style="display:flex;flex-direction:column;gap:20px">
                <div style="display:flex;align-items:flex-start;gap:16px">
                    <div style="width:44px;height:44px;border-radius:50%;background:#e8f5e9;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">📍</div>
                    <div>
                        <p style="font-weight:700;font-size:14px;color:#1a1a1a;margin-bottom:3px">Adres</p>
                        <p style="font-size:13px;color:#666;line-height:1.6">Organik Cad. No:1, Kadıköy<br>İstanbul, Türkiye</p>
                    </div>
                </div>
                <div style="display:flex;align-items:flex-start;gap:16px">
                    <div style="width:44px;height:44px;border-radius:50%;background:#e8f5e9;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">📞</div>
                    <div>
                        <p style="font-weight:700;font-size:14px;color:#1a1a1a;margin-bottom:3px">Telefon</p>
                        <p style="font-size:13px;color:#666">+90 212 000 00 00</p>
                        <p style="font-size:12px;color:#999">Hft içi 09:00 – 18:00</p>
                    </div>
                </div>
                <div style="display:flex;align-items:flex-start;gap:16px">
                    <div style="width:44px;height:44px;border-radius:50%;background:#e8f5e9;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">✉</div>
                    <div>
                        <p style="font-weight:700;font-size:14px;color:#1a1a1a;margin-bottom:3px">E-posta</p>
                        <p style="font-size:13px;color:#666">info@organishop.com.tr</p>
                        <p style="font-size:12px;color:#999">7/24 yanıt veriyoruz</p>
                    </div>
                </div>
                <div style="display:flex;align-items:flex-start;gap:16px">
                    <div style="width:44px;height:44px;border-radius:50%;background:#e8f5e9;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">🕐</div>
                    <div>
                        <p style="font-weight:700;font-size:14px;color:#1a1a1a;margin-bottom:3px">Çalışma Saatleri</p>
                        <p style="font-size:13px;color:#666">Pazartesi – Cuma: 09:00 – 18:00</p>
                        <p style="font-size:13px;color:#666">Cumartesi: 10:00 – 15:00</p>
                        <p style="font-size:12px;color:#999">Pazar kapalı</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sağ: Form -->
        <div style="background:white;border:1px solid #e0e0e0;border-radius:12px;padding:28px">
            <h2 style="font-size:16px;font-weight:800;color:#1a1a1a;margin-bottom:20px">Mesaj Gönder</h2>
            <form asp-controller="Contact" asp-action="Index" method="post">
                @Html.AntiForgeryToken()
                <div class="org-form-group">
                    <label class="org-label">Adınız Soyadınız *</label>
                    <input name="fullName" class="org-input" required placeholder="Adınız Soyadınız" />
                </div>
                <div class="org-form-group">
                    <label class="org-label">E-posta *</label>
                    <input name="email" type="email" class="org-input" required placeholder="email@ornek.com" />
                </div>
                <div class="org-form-group">
                    <label class="org-label">Mesajınız *</label>
                    <textarea name="message" class="org-textarea" required placeholder="Nasıl yardımcı olabiliriz?" style="min-height:140px"></textarea>
                </div>
                <button type="submit" class="btn-green" style="width:100%;justify-content:center;border-radius:8px;padding:12px;font-size:14px">
                    Gönder →
                </button>
            </form>
        </div>

    </div>
</div>
