<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Organi Fresh Product</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="org-nav">
        <div class="container">
            <div class="org-nav-inner">
                <a class="org-logo" asp-controller="Home" asp-action="Index">
                    <div class="org-logo-icon">O</div>
                    <div class="org-logo-text">
                        <div class="org-logo-name">organi</div>
                        <div class="org-logo-sub">Fresh Product</div>
                    </div>
                </a>
                <div class="org-nav-links">
                    <a asp-controller="Home" asp-action="Index" class="@(ViewData["Page"]?.ToString() == "Home" ? "active" : "")">Ana Sayfa</a>
                    <a asp-controller="Shop" asp-action="Index" class="@(ViewData["Page"]?.ToString() == "Shop" ? "active" : "")">Mağaza</a>
                    <a asp-controller="Cart" asp-action="Index" class="@(ViewData["Page"]?.ToString() == "Cart" ? "active" : "")">Sepet</a>
                    <a asp-controller="Compare" asp-action="Index" class="@(ViewData["Page"]?.ToString() == "Compare" ? "active" : "")">Karşılaştır</a>
                    <a asp-controller="Contact" asp-action="Index" class="@(ViewData["Page"]?.ToString() == "Contact" ? "active" : "")">İletişim</a>
                </div>
                <div class="org-nav-actions">
                    <a asp-controller="Shop" asp-action="Index" class="org-nav-btn" title="Ara">🔍</a>
                    <a asp-controller="Cart" asp-action="Index" class="org-nav-btn" title="Sepet" style="position:relative">
                        🛒
                        <span class="org-nav-badge" id="cartCount">0</span>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    @RenderBody()

    <footer class="org-footer">
        <div class="container">
            <div class="org-footer-grid">
                <div>
                    <div class="org-logo-name" style="margin-bottom:10px;font-size:20px">organi</div>
                    <p style="font-size:13px;line-height:1.7;color:rgba(255,255,255,0.55);margin-bottom:16px">Organik çiftliklerden doğrudan kapınıza teslim edilen taze ve sağlıklı ürünler.</p>
                    <div class="org-footer-email">
                        <input class="org-footer-input" type="email" placeholder="E-posta adresiniz girin..." />
                        <button class="org-footer-sub-btn">Abone Ol</button>
                    </div>
                </div>
                <div>
                    <p class="org-footer-title">Neden Bizi Seçmelisiniz?</p>
                    <ul class="org-footer-links">
                        <li><a href="#">Hakkımızda</a></li>
                        <li><a href="#">Gizlilik Politikası</a></li>
                        <li><a href="#">Kullanım Koşulları</a></li>
                        <li><a href="#">Sık Sorulan Sorular</a></li>
                    </ul>
                </div>
                <div>
                    <p class="org-footer-title">Hesabım</p>
                    <ul class="org-footer-links">
                        <li><a asp-controller="Shop" asp-action="Index">Mağaza</a></li>
                        <li><a asp-controller="Cart" asp-action="Index">Sepet</a></li>
                        <li><a asp-controller="Compare" asp-action="Index">Karşılaştır</a></li>
                        <li><a href="#">Sipariş Ver</a></li>
                    </ul>
                </div>
                <div>
                    <p class="org-footer-title">İletişim</p>
                    <ul class="org-footer-links">
                        <li><a href="#">📍 Organik Cad. No:1, İstanbul</a></li>
                        <li><a href="#">📞 +90 212 000 00 00</a></li>
                        <li><a href="#">✉ info@organishop.com.tr</a></li>
                    </ul>
                </div>
            </div>
            <div class="org-footer-bottom">
                <span>Telif Hakkı © 2025 ORGANİ. Tüm hakları saklıdır.</span>
                <a href="#" style="font-size:12px;color:rgba(255,255,255,0.5);text-decoration:none">Gizlilik Politikası | İade ve Değişim</a>
            </div>
        </div>
    </footer>

    <script>
        fetch('/Cart/Count').then(r=>r.json()).then(n=>{ document.getElementById('cartCount').textContent=n; });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
