@model Organi.Models.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Ana Sayfa"; ViewData["Page"] = "Home";
}

<!-- Hero Slider -->
<div style="position:relative;overflow:hidden;height:480px">
    <div id="heroTrack" style="display:flex;height:100%;transition:transform .6s cubic-bezier(.4,0,.2,1)">

        <div style="min-width:100%;height:100%;display:flex;align-items:center;padding:0 80px;position:relative;background-image:url('https://images.unsplash.com/photo-1488459716781-31db52582fe9?w=1400&q=80');background-size:cover;background-position:center">
            <div style="position:absolute;inset:0;background:rgba(0,0,0,0.35)"></div>
            <div style="max-width:500px;z-index:2;position:relative">
                <span style="display:inline-block;background:#4caf50;color:white;font-size:11px;font-weight:700;padding:4px 14px;border-radius:4px;margin-bottom:18px;text-transform:uppercase;letter-spacing:.05em">%100 Organik Ürünler</span>
                <h1 style="font-size:42px;font-weight:800;color:white;line-height:1.15;margin-bottom:14px">Organik Ürünler &amp;<br><span style="color:#4caf50">Sağlıklı Yaşam</span></h1>
                <p style="font-size:15px;color:rgba(255,255,255,0.85);margin-bottom:28px;line-height:1.65">Çiftliğimizden doğrudan sofranıza. En iyi organik deneyim sizi bekliyor.</p>
                <a asp-controller="Shop" asp-action="Index" style="display:inline-flex;align-items:center;gap:8px;background:#4caf50;color:white;padding:13px 30px;border-radius:30px;font-weight:700;font-size:14px;text-decoration:none">Hemen Alışveriş Yap →</a>
            </div>
        </div>

        <div style="min-width:100%;height:100%;display:flex;align-items:center;padding:0 80px;position:relative;background-image:url('https://images.unsplash.com/photo-1542838132-92c53300491e?w=1400&q=80');background-size:cover;background-position:center">
            <div style="position:absolute;inset:0;background:rgba(0,0,0,0.35)"></div>
            <div style="max-width:500px;z-index:2;position:relative">
                <span style="display:inline-block;background:#388e3c;color:white;font-size:11px;font-weight:700;padding:4px 14px;border-radius:4px;margin-bottom:18px;text-transform:uppercase;letter-spacing:.05em">Taze &amp; Doğal</span>
                <h1 style="font-size:42px;font-weight:800;color:white;line-height:1.15;margin-bottom:14px">Çiftlikten <span style="color:#4caf50">Sofranıza</span><br>Taze Teslimat</h1>
                <p style="font-size:15px;color:rgba(255,255,255,0.85);margin-bottom:28px;line-height:1.65">Günlük hasat edilen organik sebze ve meyveler kapınızda.</p>
                <a asp-controller="Shop" asp-action="Index" style="display:inline-flex;align-items:center;gap:8px;background:#388e3c;color:white;padding:13px 30px;border-radius:30px;font-weight:700;font-size:14px;text-decoration:none">Ürünleri Keşfet →</a>
            </div>
        </div>

        <div style="min-width:100%;height:100%;display:flex;align-items:center;padding:0 80px;position:relative;background-image:url('https://images.unsplash.com/photo-1610832958506-aa56368176cf?w=1400&q=80');background-size:cover;background-position:center">
            <div style="position:absolute;inset:0;background:background:rgba(0,0,0,0.35)"></div>
            <div style="max-width:500px;z-index:2;position:relative">
                <span style="display:inline-block;background:#f57f17;color:white;font-size:11px;font-weight:700;padding:4px 14px;border-radius:4px;margin-bottom:18px;text-transform:uppercase;letter-spacing:.05em">Sebzelerde %20 İndirim</span>
                <h1 style="font-size:42px;font-weight:800;color:white;line-height:1.15;margin-bottom:14px">Haftanın <span style="color:#f57f17">Kampanyaları</span><br>Kaçırmayın!</h1>
                <p style="font-size:15px;color:rgba(255,255,255,0.85);margin-bottom:28px;line-height:1.65">Seçili organik ürünlerde özel indirimler bu hafta sona eriyor.</p>
                <a asp-controller="Shop" asp-action="Index" style="display:inline-flex;align-items:center;gap:8px;background:#f57f17;color:white;padding:13px 30px;border-radius:30px;font-weight:700;font-size:14px;text-decoration:none">Kampanyaları Gör →</a>
            </div>
        </div>

    </div>
    <button onclick="heroSlide(-1)" style="position:absolute;left:16px;top:50%;transform:translateY(-50%);width:46px;height:46px;border-radius:50%;background:white;border:1px solid #ddd;font-size:18px;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,.1);z-index:10">‹</button>
    <button onclick="heroSlide(1)" style="position:absolute;right:16px;top:50%;transform:translateY(-50%);width:46px;height:46px;border-radius:50%;background:white;border:1px solid #ddd;font-size:18px;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,.1);z-index:10">›</button>
    <div style="position:absolute;bottom:18px;left:50%;transform:translateX(-50%);display:flex;gap:6px" id="heroDots">
        <button onclick="heroGo(0)" class="hdot active" style="width:20px;height:8px;border-radius:4px;background:#4caf50;border:none;cursor:pointer"></button>
        <button onclick="heroGo(1)" class="hdot" style="width:8px;height:8px;border-radius:50%;background:rgba(76,175,80,.3);border:none;cursor:pointer"></button>
        <button onclick="heroGo(2)" class="hdot" style="width:8px;height:8px;border-radius:50%;background:rgba(76,175,80,.3);border:none;cursor:pointer"></button>
    </div>
</div>

<!-- Features Band -->
<div style="background:white;border-top:1px solid #e0e0e0;border-bottom:1px solid #e0e0e0">
    <div class="container">
        <div style="display:grid;grid-template-columns:repeat(4,1fr)">
            @foreach (var item in new[]{
                        new{Icon="🌿",Title="Organik Çiftlik Ürünleri",Sub="Sertifikalı organik"},
                        new{Icon="🏠",Title="Ücretsiz Kapıya Teslimat",Sub="99₺ üzeri siparişlerde"},
                        new{Icon="🏷",Title="Haftanın Kampanyaları",Sub="Her hafta yeni indirimler"},
                        new{Icon="🥬",Title="Sebzelerde %20 İndirim",Sub="Seçili ürünlerde"}
                        })
            {
                <div style="display:flex;align-items:center;gap:14px;padding:20px 24px;border-right:1px solid #e0e0e0">
                    <div style="width:46px;height:46px;border-radius:50%;background:#e8f5e9;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">@item.Icon</div>
                    <div>
                        <p style="font-weight:700;font-size:13px;color:#1a1a1a;margin-bottom:2px">@item.Title</p>
                        <p style="font-size:12px;color:#999">@item.Sub</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Featured Products -->
@if (Model.FeaturedProducts.Any())
{
    <div class="container">
        <div class="org-section">
            <h2 class="org-section-title">Öne Çıkan Ürünler</h2>
            <p class="org-section-sub">En çok tercih edilen organik ürünlerimiz</p>
            <div class="org-product-grid">
                @foreach (var p in Model.FeaturedProducts.Take(6))
                {
                    <div class="org-product-card">
                        <img src="@p.ImageUrl" alt="@p.Name" class="org-product-img" onerror="this.src='/images/placeholder.png'" />
                        <div class="org-product-body">
                            @if (!string.IsNullOrEmpty(p.Badge))
                            {
                                <span class="org-product-badge @(p.Badge == "HOT" ? "org-product-badge--hot" : "")">@p.Badge</span>
                            }
                            <a asp-controller="Shop" asp-action="Detail" asp-route-id="@p.Id" style="text-decoration:none;color:inherit">
                                <p class="org-product-name">@p.Name</p>
                            </a>
                            <div class="org-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span>@(i <= (int)p.Rating ? "★" : "☆")</span>
                                }
                                <span>(@p.RatingCount)</span>
                            </div>
                            <div class="org-product-price">
                                <span class="org-product-price-current">₺@p.Price.ToString("F2")</span>
                                @if (p.OldPrice.HasValue)
                                {
                                    <span class="org-product-price-old">₺@p.OldPrice.Value.ToString("F2")</span>
                                }
                                <span class="org-product-price-unit">/ @p.Unit</span>
                            </div>
                            <form asp-controller="Cart" asp-action="Add" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@p.Id" />
                                <button type="submit" class="org-add-btn">🛒 Sepete Ekle</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        let hc=0; const ht=3; let htimer;
        function heroGo(i){ hc=i; document.getElementById('heroTrack').style.transform=`translateX(-${i*100}%)`; document.querySelectorAll('.hdot').forEach((d,j)=>{ d.style.width=j===i?'20px':'8px'; d.style.borderRadius=j===i?'4px':'50%'; d.style.background=j===i?'#4caf50':'rgba(76,175,80,.3)'; }); clearInterval(htimer); htimer=setInterval(()=>heroSlide(1),5000); }
        function heroSlide(d){ heroGo((hc+d+ht)%ht); }
        htimer=setInterval(()=>heroSlide(1),5000);
    </script>
}
