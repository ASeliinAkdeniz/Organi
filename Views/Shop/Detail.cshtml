@model Organi.Models.Entities.Product
@{
    ViewData["Title"] = Model.Name; ViewData["Page"] = "Shop";
}

<div class="org-page-header">
    <div class="org-page-header-content">
        <h1>@Model.Name</h1>
        <div class="org-breadcrumb">
            <span class="org-breadcrumb-icon">🏠</span>
            <a asp-controller="Home" asp-action="Index">Ana Sayfa</a>
            <span>›</span>
            <a asp-controller="Shop" asp-action="Index">Mağaza</a>
            <span>›</span>
            <span style="color:white">@Model.Name</span>
        </div>
    </div>
</div>

<div class="container" style="padding-top:40px;padding-bottom:60px">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start">

        <!-- Sol: Görsel -->
        <div>
            <div style="background:#f5f5f5;border-radius:16px;overflow:hidden;aspect-ratio:1;display:flex;align-items:center;justify-content:center">
                <img src="@Model.ImageUrl" alt="@Model.Name"
                     style="width:100%;height:100%;object-fit:cover"
                     onerror="this.src='/images/placeholder.png'" />
            </div>
        </div>

        <!-- Sağ: Bilgiler -->
        <div>
            @if (!string.IsNullOrEmpty(Model.Badge))
            {
                <span class="org-product-badge @(Model.Badge == "HOT" ? "org-product-badge--hot" : "")">@Model.Badge</span>
            }

            <h1 style="font-size:26px;font-weight:800;color:#1a1a1a;margin:10px 0 8px">@Model.Name</h1>

            <div class="org-stars" style="font-size:16px;margin-bottom:12px">
                @for (int i = 1; i <= 5; i++)
                {
                    <span>@(i <= (int)Model.Rating ? "★" : "☆")</span>
                }
                <span style="font-size:13px;color:#999;margin-left:4px">(@Model.RatingCount değerlendirme)</span>
            </div>

            <div style="display:flex;align-items:baseline;gap:10px;margin-bottom:16px">
                <span style="font-size:32px;font-weight:800;color:#4caf50">₺@Model.Price.ToString("F2")</span>
                @if (Model.OldPrice.HasValue)
                {
                    <span style="font-size:18px;color:#999;text-decoration:line-through">₺@Model.OldPrice.Value.ToString("F2")</span>
                }
                <span style="font-size:14px;color:#999">/ @Model.Unit</span>
            </div>

            <p style="font-size:14px;color:#555;line-height:1.7;margin-bottom:20px">@Model.Description</p>

            <div style="display:flex;align-items:center;gap:8px;margin-bottom:24px">
                <span style="font-size:13px;color:#666">Stok durumu:</span>
                @if (Model.Stock > 0)
                {
                    <span style="color:#4caf50;font-weight:700;font-size:13px">✓ Stokta var (@Model.Stock @Model.Unit)</span>
                }
                else
                {
                    <span style="color:#e53935;font-weight:700;font-size:13px">✗ Tükendi</span>
                }
            </div>

            <div style="display:flex;gap:12px;margin-bottom:28px">
                <form asp-controller="Cart" asp-action="Add" method="post" style="flex:1">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <button type="submit" class="btn-green" style="width:100%;justify-content:center;border-radius:8px;padding:13px;font-size:15px">
                        🛒 Sepete Ekle
                    </button>
                </form>
                <form asp-controller="Compare" asp-action="Add" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <button type="submit" class="btn-outline" style="padding:13px 20px;border-radius:8px" title="Karşılaştırmaya Ekle">⇄ Karşılaştır</button>
                </form>
            </div>

            <!-- Besin Değerleri -->
            @if (Model.CaloriesPer100g.HasValue)
            {
                <div style="background:#f9fbe7;border:1px solid #c5e1a5;border-radius:10px;padding:18px">
                    <p style="font-weight:700;font-size:13px;color:#388e3c;margin-bottom:12px">🥗 Besin Değerleri @(Model.ServingSize != null ? $"({Model.ServingSize})" : "(100g başına)")</p>
                    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px">
                        <div style="text-align:center;background:white;border-radius:8px;padding:10px">
                            <p style="font-size:18px;font-weight:800;color:#4caf50">@Model.CaloriesPer100g</p>
                            <p style="font-size:11px;color:#999">Kalori</p>
                        </div>
                        @if (Model.FatPer100g.HasValue)
                        {
                            <div style="text-align:center;background:white;border-radius:8px;padding:10px">
                                <p style="font-size:18px;font-weight:800;color:#4caf50">@Model.FatPer100g</p>
                                <p style="font-size:11px;color:#999">Yağ (g)</p>
                            </div>
                        }
                        @if (Model.CarbsPer100g.HasValue)
                        {
                            <div style="text-align:center;background:white;border-radius:8px;padding:10px">
                                <p style="font-size:18px;font-weight:800;color:#4caf50">@Model.CarbsPer100g</p>
                                <p style="font-size:11px;color:#999">Karbonhidrat (g)</p>
                            </div>
                        }
                        @if (Model.ProteinPer100g.HasValue)
                        {
                            <div style="text-align:center;background:white;border-radius:8px;padding:10px">
                                <p style="font-size:18px;font-weight:800;color:#4caf50">@Model.ProteinPer100g</p>
                                <p style="font-size:11px;color:#999">Protein (g)</p>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div style="margin-top:24px">
        <a asp-controller="Shop" asp-action="Index" class="btn-outline">← Mağazaya Dön</a>
    </div>
</div>
